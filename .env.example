# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development  # development | production

# Security
ADMIN_SECRET=bumblebee 

# Limits
PLAYWRIGHT_TIMEOUT_MS=60000
MAX_PAGE_SIZE_MB=50
MAX_IMAGES=1000
IMAGE_DOWNLOAD_TIMEOUT_S=20
MAX_IMAGE_SIZE_MB=10

# SSRF Protection
ALLOWED_DOMAINS=
BLOCKED_DOMAINS=

# Logging
LOG_LEVEL=INFO

# CORS Configuration
# Use "*" to allow all origins (dev only), or comma-separated list for production
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*,Authorization,Content-Type
CORS_EXPOSE_HEADERS=

# Batch
batch_max_urls=30